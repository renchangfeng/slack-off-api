generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CheckInStatus {
  active
  completed
  cancelled
  invalidated
}

enum LeaderboardWindow {
  daily
  weekly
  monthly
  all_time
}

enum BeanRarity {
  common
  uncommon
  rare
  epic
  legendary
}

enum BeanTheme {
  office
  restroom
  daydream
}

enum RewardSourceType {
  check_in
  activity
  achievement
  bean_draw
  progression
  admin
}

enum ProgressionPeriodType {
  daily
  weekly
}

enum RewardType {
  score
  draw_progress
  draw_chance
  bean
  cosmetic
}

enum AchievementRuleType {
  first_checkin
  streak
  total_duration
  activity_count
  collection_count
  weekly_top_rank
}

enum CosmeticType {
  badge
  title
}

enum ActivityCategory {
  game
  rest
  office_theater
  physical
  imagination
  absurd
  tiny_task
}

enum ActivityDifficulty {
  easy
  normal
  hard
}

enum ActivityAssignmentStatus {
  active
  completed
  skipped
  expired
}

enum ActivityFeedbackType {
  liked
  neutral
  dislike_similar
  want_weirder
  too_much_work
  too_long
  too_physical
  shorter
}

enum ActivityFeedbackSource {
  completion
  skip
}

enum SocialReactionType {
  tissue
  like
}

enum FishRarity {
  common
  uncommon
  rare
  epic
  legendary
}

enum FishTheme {
  office
  restroom
  daydream
}

enum FishTankResourceType {
  food
  bubble
  hatch_progress

  @@map("fish_tank_resource_type")
}

enum TankDecorationSlot {
  background
  plant
  prop
  ambient

  @@map("tank_decoration_slot")
}

enum TankDecorationRarity {
  common
  uncommon
  rare
  epic
  legendary

  @@map("tank_decoration_rarity")
}

model User {
  id                          String                       @id @default(uuid()) @db.Uuid
  authSubject                 String                       @unique @map("auth_subject")
  email                       String?                      @unique
  displayName                 String                       @map("display_name")
  friendCode                  String?                      @unique @map("friend_code")
  avatarUrl                   String?                      @map("avatar_url")
  createdAt                   DateTime                     @default(now()) @map("created_at")
  updatedAt                   DateTime                     @updatedAt @map("updated_at")
  deletedAt                   DateTime?                    @map("deleted_at")
  profile                     UserProfile?
  stats                       UserStats?
  checkInSessions             CheckInSession[]
  leaderboardScores           LeaderboardScore[]
  rewardLedger                RewardLedger[]
  beanInventory               BeanInventory[]
  achievements                UserAchievement[]
  cosmetics                   UserCosmetic[]
  activityAssignments         ActivityAssignment[]
  activityFeedbackEvents      ActivityFeedbackEvent[]
  progressionPeriods          ProgressionGoalPeriod[]
  beanShowcase                BeanShowcase[]
  actorAuditEvents            AuditEvent[]                 @relation("AuditActor")
  targetAuditEvents           AuditEvent[]                 @relation("AuditTarget")
  friendshipsAsA              Friendship[]                 @relation("FriendshipUserA")
  friendshipsAsB              Friendship[]                 @relation("FriendshipUserB")
  ownedSquads                 Squad[]                      @relation("SquadOwner")
  squadMembership             SquadMembership?
  ownedCompanies              Company[]                    @relation("CompanyOwner")
  companyMembership           CompanyMembership?
  sentReactions               SocialReaction[]             @relation("ReactionSender")
  receivedReactions           SocialReaction[]             @relation("ReactionRecipient")
  userTank                    UserTank?
  userFishes                  UserFish[]
  fishCareEvents              FishCareEvent[]
  fishHatchEvents             FishHatchEvent[]
  fishTankResourceLedger      FishTankResourceLedger[]
  userTankDecorations         UserTankDecoration[]
  userTankEquippedDecorations UserTankEquippedDecoration[]
  tankDecorationEquipEvents   TankDecorationEquipEvent[]
  fishTankDisplayOrderEvents  FishTankDisplayOrderEvent[]

  @@map("users")
}

model Friendship {
  id        String   @id @default(uuid()) @db.Uuid
  userAId   String   @map("user_a_id") @db.Uuid
  userBId   String   @map("user_b_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  userA     User     @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@map("friendships")
}

model Squad {
  id          String            @id @default(uuid()) @db.Uuid
  name        String
  inviteCode  String            @unique @map("invite_code")
  ownerId     String            @map("owner_id") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at")
  owner       User              @relation("SquadOwner", fields: [ownerId], references: [id])
  memberships SquadMembership[]

  @@map("squads")
}

model SquadMembership {
  userId   String   @id @map("user_id") @db.Uuid
  squadId  String   @map("squad_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  squad    Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@index([squadId])
  @@map("squad_memberships")
}

model Company {
  id          String              @id @default(uuid()) @db.Uuid
  name        String
  inviteCode  String              @unique @map("invite_code")
  ownerId     String              @map("owner_id") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at")
  owner       User                @relation("CompanyOwner", fields: [ownerId], references: [id])
  memberships CompanyMembership[]

  @@map("companies")
}

model CompanyMembership {
  userId         String   @id @map("user_id") @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  anonymousAlias String   @map("anonymous_alias")
  joinedAt       DateTime @default(now()) @map("joined_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, anonymousAlias])
  @@index([companyId])
  @@map("company_memberships")
}

model SocialReaction {
  id           String             @id @default(uuid()) @db.Uuid
  senderId     String             @map("sender_id") @db.Uuid
  recipientId  String             @map("recipient_id") @db.Uuid
  reactionType SocialReactionType @map("reaction_type")
  reactionDate DateTime           @map("reaction_date") @db.Date
  createdAt    DateTime           @default(now()) @map("created_at")
  sender       User               @relation("ReactionSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient    User               @relation("ReactionRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([senderId, recipientId, reactionType, reactionDate])
  @@index([senderId, reactionDate])
  @@index([recipientId, reactionDate])
  @@map("social_reactions")
}

model UserProfile {
  userId          String    @id @map("user_id") @db.Uuid
  bio             String?
  equippedBadgeId String?   @map("equipped_badge_id") @db.Uuid
  equippedTitleId String?   @map("equipped_title_id") @db.Uuid
  privacyMode     String    @default("public_alias") @map("privacy_mode")
  timezone        String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id])
  equippedBadge   Cosmetic? @relation("EquippedBadge", fields: [equippedBadgeId], references: [id])
  equippedTitle   Cosmetic? @relation("EquippedTitle", fields: [equippedTitleId], references: [id])

  @@map("user_profiles")
}

model CheckInSession {
  id                      String        @id @default(uuid()) @db.Uuid
  userId                  String        @map("user_id") @db.Uuid
  startedAt               DateTime      @map("started_at")
  endedAt                 DateTime?     @map("ended_at")
  durationSeconds         Int?          @map("duration_seconds")
  eligibleDurationSeconds Int?          @map("eligible_duration_seconds")
  status                  CheckInStatus
  invalidReason           String?       @map("invalid_reason")
  rewarded                Boolean       @default(false)
  idempotencyKey          String?       @unique @map("idempotency_key")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")
  user                    User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, status])
  @@map("check_in_sessions")
}

model UserStats {
  userId                  String    @id @map("user_id") @db.Uuid
  totalSessions           Int       @default(0) @map("total_sessions")
  totalDurationSeconds    Int       @default(0) @map("total_duration_seconds")
  eligibleDurationSeconds Int       @default(0) @map("eligible_duration_seconds")
  currentStreakDays       Int       @default(0) @map("current_streak_days")
  longestStreakDays       Int       @default(0) @map("longest_streak_days")
  lastEligibleCheckinDate DateTime? @map("last_eligible_checkin_date") @db.Date
  drawChances             Int       @default(0) @map("draw_chances")
  drawProgress            Int       @default(0) @map("draw_progress")
  beanFragments           Int       @default(0) @map("bean_fragments")
  beanPityCount           Int       @default(0) @map("bean_pity_count")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  user                    User      @relation(fields: [userId], references: [id])

  @@map("user_stats")
}

model LeaderboardScore {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  window      LeaderboardWindow
  windowStart DateTime          @map("window_start")
  score       Int               @default(0)
  rankCache   Int?              @map("rank_cache")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  user        User              @relation(fields: [userId], references: [id])

  @@unique([userId, window, windowStart])
  @@index([window, windowStart, score])
  @@map("leaderboard_scores")
}

model BeanDefinition {
  id          String          @id @default(uuid()) @db.Uuid
  code        String          @unique
  name        String
  rarity      BeanRarity
  theme       BeanTheme
  description String
  imageKey    String?         @map("image_key")
  active      Boolean         @default(true)
  weight      Int
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  inventory   BeanInventory[]
  showcase    BeanShowcase[]

  @@map("bean_definitions")
}

model BeanShowcase {
  userId    String         @map("user_id") @db.Uuid
  beanId    String         @map("bean_id") @db.Uuid
  position  Int
  updatedAt DateTime       @updatedAt @map("updated_at")
  user      User           @relation(fields: [userId], references: [id])
  bean      BeanDefinition @relation(fields: [beanId], references: [id])

  @@id([userId, position])
  @@unique([userId, beanId])
  @@map("bean_showcase")
}

model BeanInventory {
  userId          String         @map("user_id") @db.Uuid
  beanId          String         @map("bean_id") @db.Uuid
  quantity        Int            @default(0)
  firstObtainedAt DateTime       @map("first_obtained_at")
  lastObtainedAt  DateTime       @map("last_obtained_at")
  user            User           @relation(fields: [userId], references: [id])
  bean            BeanDefinition @relation(fields: [beanId], references: [id])

  @@id([userId, beanId])
  @@map("bean_inventory")
}

model RewardLedger {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  sourceType     RewardSourceType @map("source_type")
  sourceId       String?          @map("source_id") @db.Uuid
  rewardType     RewardType       @map("reward_type")
  amount         Int
  metadata       Json
  idempotencyKey String?          @unique @map("idempotency_key")
  createdAt      DateTime         @default(now()) @map("created_at")
  user           User             @relation(fields: [userId], references: [id])

  @@index([userId, sourceType])
  @@map("reward_ledger")
}

model Achievement {
  id           String              @id @default(uuid()) @db.Uuid
  code         String              @unique
  name         String
  description  String
  ruleType     AchievementRuleType @map("rule_type")
  ruleConfig   Json                @map("rule_config")
  rewardConfig Json                @map("reward_config")
  active       Boolean             @default(true)
  users        UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  userId          String      @map("user_id") @db.Uuid
  achievementId   String      @map("achievement_id") @db.Uuid
  unlockedAt      DateTime    @map("unlocked_at")
  rewardClaimedAt DateTime?   @map("reward_claimed_at")
  user            User        @relation(fields: [userId], references: [id])
  achievement     Achievement @relation(fields: [achievementId], references: [id])

  @@id([userId, achievementId])
  @@map("user_achievements")
}

model Cosmetic {
  id                    String         @id @default(uuid()) @db.Uuid
  code                  String         @unique
  name                  String
  description           String
  cosmeticType          CosmeticType   @map("cosmetic_type")
  rarity                BeanRarity
  active                Boolean        @default(true)
  users                 UserCosmetic[]
  equippedBadgeProfiles UserProfile[]  @relation("EquippedBadge")
  equippedTitleProfiles UserProfile[]  @relation("EquippedTitle")

  @@map("cosmetics")
}

model UserCosmetic {
  userId     String           @map("user_id") @db.Uuid
  cosmeticId String           @map("cosmetic_id") @db.Uuid
  unlockedAt DateTime         @map("unlocked_at")
  sourceType RewardSourceType @map("source_type")
  user       User             @relation(fields: [userId], references: [id])
  cosmetic   Cosmetic         @relation(fields: [cosmeticId], references: [id])

  @@id([userId, cosmeticId])
  @@map("user_cosmetics")
}

model ActivityTemplate {
  id               String                  @id @default(uuid()) @db.Uuid
  code             String                  @unique
  title            String
  description      String
  category         ActivityCategory
  difficulty       ActivityDifficulty
  rewardConfig     Json                    @map("reward_config")
  cooldownSeconds  Int                     @map("cooldown_seconds")
  dailyRewardLimit Int                     @map("daily_reward_limit")
  active           Boolean                 @default(true)
  assignments      ActivityAssignment[]
  feedbackEvents   ActivityFeedbackEvent[]

  @@map("activity_templates")
}

model ActivityAssignment {
  id             String                   @id @default(uuid()) @db.Uuid
  userId         String                   @map("user_id") @db.Uuid
  templateId     String                   @map("template_id") @db.Uuid
  status         ActivityAssignmentStatus
  assignedAt     DateTime                 @map("assigned_at")
  completedAt    DateTime?                @map("completed_at")
  expiresAt      DateTime?                @map("expires_at")
  rewarded       Boolean                  @default(false)
  idempotencyKey String?                  @unique @map("idempotency_key")
  user           User                     @relation(fields: [userId], references: [id])
  template       ActivityTemplate         @relation(fields: [templateId], references: [id])
  feedbackEvents ActivityFeedbackEvent[]

  @@index([userId, status])
  @@index([userId, status, assignedAt])
  @@map("activity_assignments")
}

model ActivityFeedbackEvent {
  id               String                 @id @default(uuid()) @db.Uuid
  userId           String                 @map("user_id") @db.Uuid
  assignmentId     String?                @map("assignment_id") @db.Uuid
  templateId       String                 @map("template_id") @db.Uuid
  category         ActivityCategory
  feedbackType     ActivityFeedbackType   @map("feedback_type")
  feedbackSource   ActivityFeedbackSource @map("feedback_source")
  skipReason       String?                @map("skip_reason")
  interactionTypes Json                   @map("interaction_types")
  metadata         Json
  createdAt        DateTime               @default(now()) @map("created_at")
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment       ActivityAssignment?    @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  template         ActivityTemplate       @relation(fields: [templateId], references: [id])

  @@unique([userId, assignmentId, feedbackType, feedbackSource])
  @@index([userId, createdAt])
  @@index([userId, templateId, createdAt])
  @@index([userId, category, createdAt])
  @@map("activity_feedback_events")
}

model ProgressionGoalPeriod {
  id          String                @id @default(uuid()) @db.Uuid
  userId      String                @map("user_id") @db.Uuid
  periodType  ProgressionPeriodType @map("period_type")
  periodStart DateTime              @map("period_start")
  claimedAt   DateTime?             @map("claimed_at")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  user        User                  @relation(fields: [userId], references: [id])

  @@unique([userId, periodType, periodStart])
  @@index([userId, periodType])
  @@map("progression_goal_periods")
}

model FishDefinition {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  name        String
  rarity      FishRarity
  theme       FishTheme
  personality String
  artKey      String           @map("art_key")
  sourceHint  String           @map("source_hint")
  active      Boolean          @default(true)
  sortOrder   Int              @default(0) @map("sort_order")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  userFishes  UserFish[]
  hatchEvents FishHatchEvent[]

  @@map("fish_definitions")
}

model UserTank {
  userId    String     @id @map("user_id") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  user      User       @relation(fields: [userId], references: [id])
  fish      UserFish[]

  @@map("user_tanks")
}

model UserFish {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  fishDefinitionId String         @map("fish_definition_id") @db.Uuid
  acquiredSource   String         @map("acquired_source")
  displayOrder     Int            @default(0) @map("display_order")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  user             User           @relation(fields: [userId], references: [id], map: "user_fish_user_id_user_fkey")
  tank             UserTank       @relation(fields: [userId], references: [userId], map: "user_fish_user_id_tank_fkey")
  definition       FishDefinition @relation(fields: [fishDefinitionId], references: [id])

  @@unique([userId, fishDefinitionId])
  @@index([userId])
  @@map("user_fish")
}

model FishCareEvent {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  interactionType String   @map("interaction_type")
  idempotencyKey  String   @map("idempotency_key")
  resultMetadata  Json     @map("result_metadata")
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, idempotencyKey])
  @@index([userId, interactionType, createdAt])
  @@map("fish_care_events")
}

model FishHatchEvent {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  fishDefinitionId String         @map("fish_definition_id") @db.Uuid
  idempotencyKey   String         @map("idempotency_key")
  hatchCost        Int            @map("hatch_cost")
  outcomeCode      String         @map("outcome_code")
  duplicate        Boolean        @default(false)
  resultMetadata   Json           @map("result_metadata")
  createdAt        DateTime       @default(now()) @map("created_at")
  user             User           @relation(fields: [userId], references: [id])
  definition       FishDefinition @relation(fields: [fishDefinitionId], references: [id])

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([fishDefinitionId])
  @@map("fish_hatch_events")
}

model FishTankResourceLedger {
  id             String               @id @default(uuid()) @db.Uuid
  userId         String               @map("user_id") @db.Uuid
  resourceType   FishTankResourceType @map("resource_type")
  quantity       Int
  sourceType     String               @map("source_type")
  sourceId       String?              @map("source_id") @db.Uuid
  idempotencyKey String               @map("idempotency_key")
  metadata       Json
  createdAt      DateTime             @default(now()) @map("created_at")
  user           User                 @relation(fields: [userId], references: [id])

  @@unique([userId, idempotencyKey])
  @@index([userId, resourceType])
  @@index([userId, sourceType, sourceId])
  @@map("fish_tank_resource_ledger")
}

model TankDecorationDefinition {
  id                  String                       @id @default(uuid()) @db.Uuid
  code                String                       @unique
  name                String
  type                TankDecorationSlot
  rarity              TankDecorationRarity
  theme               String?
  artKey              String                       @map("art_key")
  unlockHint          String                       @map("unlock_hint")
  active              Boolean                      @default(true)
  sortOrder           Int                          @default(0) @map("sort_order")
  createdAt           DateTime                     @default(now()) @map("created_at")
  updatedAt           DateTime                     @updatedAt @map("updated_at")
  ownedDecorations    UserTankDecoration[]
  equippedDecorations UserTankEquippedDecoration[]
  equipEvents         TankDecorationEquipEvent[]

  @@map("tank_decoration_definitions")
}

model UserTankDecoration {
  userId                 String                   @map("user_id") @db.Uuid
  decorationDefinitionId String                   @map("decoration_definition_id") @db.Uuid
  quantity               Int                      @default(1)
  acquiredSource         String                   @map("acquired_source")
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")
  user                   User                     @relation(fields: [userId], references: [id])
  definition             TankDecorationDefinition @relation(fields: [decorationDefinitionId], references: [id])

  @@id([userId, decorationDefinitionId])
  @@index([userId])
  @@map("user_tank_decorations")
}

model UserTankEquippedDecoration {
  userId                 String                   @map("user_id") @db.Uuid
  slot                   TankDecorationSlot
  decorationDefinitionId String                   @map("decoration_definition_id") @db.Uuid
  equippedAt             DateTime                 @default(now()) @map("equipped_at")
  user                   User                     @relation(fields: [userId], references: [id])
  definition             TankDecorationDefinition @relation(fields: [decorationDefinitionId], references: [id])

  @@id([userId, slot])
  @@index([userId])
  @@map("user_tank_equipped_decorations")
}

model TankDecorationEquipEvent {
  id                     String                   @id @default(uuid()) @db.Uuid
  userId                 String                   @map("user_id") @db.Uuid
  slot                   TankDecorationSlot
  decorationDefinitionId String                   @map("decoration_definition_id") @db.Uuid
  idempotencyKey         String                   @map("idempotency_key")
  outcomeCode            String                   @map("outcome_code")
  replay                 Boolean                  @default(false)
  resultMetadata         Json                     @map("result_metadata")
  createdAt              DateTime                 @default(now()) @map("created_at")
  user                   User                     @relation(fields: [userId], references: [id])
  definition             TankDecorationDefinition @relation(fields: [decorationDefinitionId], references: [id])

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([decorationDefinitionId])
  @@map("tank_decoration_equip_events")
}

model FishTankDisplayOrderEvent {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  idempotencyKey   String   @map("idempotency_key")
  displayedFishIds String[] @map("displayed_fish_ids") @db.Uuid
  resultMetadata   Json     @map("result_metadata")
  createdAt        DateTime @default(now()) @map("created_at")
  user             User     @relation(fields: [userId], references: [id])

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@map("fish_tank_display_order_events")
}

model AuditEvent {
  id           String   @id @default(uuid()) @db.Uuid
  eventType    String   @map("event_type")
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  targetUserId String?  @map("target_user_id") @db.Uuid
  requestId    String?  @map("request_id")
  traceId      String?  @map("trace_id")
  spanId       String?  @map("span_id")
  sourceType   String?  @map("source_type")
  sourceId     String?  @map("source_id") @db.Uuid
  metadata     Json
  createdAt    DateTime @default(now()) @map("created_at")
  actorUser    User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  targetUser   User?    @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([traceId])
  @@index([eventType, createdAt])
  @@map("audit_events")
}
