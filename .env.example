# Slack Off API environment examples.
# Copy this file to .env for local development or map these variables in your server runtime.

# local | staging | production are deployment labels for operators.
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# env loads runtime policy defaults from src/config/runtime.ts.
# nacos loads runtime policy JSON from Nacos while secrets still come from env.
CONFIG_SOURCE=env
NACOS_SERVER_URL=
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
NACOS_DATA_ID=slack-off-api.json

# Required for real database access.
DATABASE_URL=postgresql://slack_off:slack_off@localhost:5432/slack_off

# Optional cache. Leave empty to run without Redis in local dev.
REDIS_URL=redis://localhost:6379

# Required outside local mock/testing. Keep this secret out of config files.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# Optional error reporting.
SENTRY_DSN=
